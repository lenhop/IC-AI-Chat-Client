# 复制为仓库根目录 .env 后本地修改（勿提交含密钥的 .env）
#
# Standalone（python -m uvicorn app.main:app）：仅加载本仓库根目录的 .env；
#  文件缺失或当前 LLM_BACKEND 所需变量未设置会导致进程启动失败。
# 二次集成：不要依赖本项目的 HTTP 接口做远程集成；在宿主代码中
#  ``from app.integrations import RuntimeConfig, stream_chat`` 并传入 runtime=...。
APP_DEBUG=true
SECRET_KEY=change-me-to-a-random-secret
UVICORN_HOST=0.0.0.0
UVICORN_PORT=8000

# ============================================
# DeepSeek
# ============================================
DEEPSEEK_API_KEY=replace-with-your-key
DEEPSEEK_LLM_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_REQUEST_TIMEOUT=600

# ============================================
# Ollama Configurations
# ============================================
OLLAMA_GENERATE_MODEL=qwen3:1.7b
OLLAMA_REQUEST_TIMEOUT=600
OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_BASE_URL=http://8.163.3.40:11434
OLLAMA_EMBED_MODEL=all-minilm:latest

LLM_BACKEND=deepseek

# LLM transport capability: local | http.
# Acceptance/deploy default is split mode: use http (UI -> LLM service).
LLM_TRANSPORT=http
# Required when LLM_TRANSPORT=http: LLM service base URL (no trailing slash).
LLM_SERVICE_URL=http://127.0.0.1:8001
# Local fallback for dev/debug only (not default acceptance mode):
# LLM_TRANSPORT=local
# 流式读取超时（秒）
LLM_SERVICE_TIMEOUT_SECONDS=120
# 可选：微服务若校验 Authorization: Bearer …
LLM_SERVICE_API_KEY=

# ============================================
# v3.5 Message Ingress / Forwarding
# ============================================
# UI ingress API path (must start with /)
CHAT_UI_INGRESS_PATH=/v1/messages/test
# Downstream ingress endpoint for query forwarding
# 统一使用 LLM 流式接口：/v1/chat/stream
CHAT_UI_FORWARD_URL=http://127.0.0.1:8001/v1/chat/stream
CHAT_UI_FORWARD_TIMEOUT_SECONDS=30
# Optional bearer token for UI forwarding
CHAT_UI_FORWARD_API_KEY=

# Gradio 客户端皮肤：business（商务，默认）| warm（温馨）| minimal（简约）
GRADIO_UI_THEME=business

USER_ID=local-dev
SESSION_ID=

# ============================================
# Redis（M3 可选：会话与消息持久化）
# ============================================
# false 时不连接 Redis，行为与 M2 一致
REDIS_ENABLED=false
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_KEY_PREFIX=icai:
# 会话 meta / messages 过期时间（秒），每次写入会续期
REDIS_SESSION_TTL_SECONDS=2592000

# ============================================
# 会话记忆与 Prompt 模板（需 Redis 时生效）
# ============================================
# Gradio 首屏与 prompt 历史：最近 N 轮（一轮 = query + answer）；0 = 不截断显示全部
MEMORY_ROUNDS=3
# messages：OpenAI 多轮 messages（默认）；prompt_template：用 app/services/chat_prompt.md 拼单条 user 再调 LLM（需 REDIS_ENABLED=true）
CHAT_MODE=messages

# Gradio：是否展示可选消息类型（query/answer 始终展示）。true | 1 | yes | on 为开启；默认开启。
CLARIFICATION_MESSAGE_DISPLAY_ENABLE=true
REWRITING_MESSAGE_DISPLAY_ENABLE=true
CLASSIFICATION_MESSAGE_DISPLAY_ENABLE=true
PLAN_MESSAGE_DISPLAY_ENABLE=true
REASON_MESSAGE_DISPLAY_ENABLE=true
CONTEXT_MESSAGE_DISPLAY_ENABLE=true
DISPATCHER_MESSAGE_DISPLAY_ENABLE=true
